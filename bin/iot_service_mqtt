#!/usr/bin/env bash

if [[ "$1" = "help" || "$1" = "-h" || "$1" = "--help" || -z "$1" ]]; then
cat << EOF
Syntax: iot_service_mqtt <start|stop|status> [interface]
EOF
exit 0
fi

[ "$IOTEMPOWER_ACTIVE" = "yes" ] || { echo "IoTempower not active, aborting." 1>&2; exit 1; }

ACTION="$1"
shift

case "$ACTION" in
    start)
        exec mqtt_starter "${1:-scanif}"
        ;;
    stop)
        pkill mosquitto || true
        ;;
    status)
        if pgrep -x mosquitto >/dev/null; then
            echo "mqtt: running"
        else
            echo "mqtt: not running"
        fi
        ;;
    *)
        echo "Unknown action: $ACTION" 1>&2
        exit 1
        ;;
esac
