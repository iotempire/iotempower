#!/usr/bin/env bash
if [[ "$*" = "help" || "$*" = "-h" || "$*" = "--help" ]]; then
cat << EOF
Syntax: accesspoint [show] [--wlan IFACE] [--gateway IP] [--wlan2 IFACE] [--gateway2 IP] [--double-nat]

accesspoint creates a local accesspoint corresponding to parameters set
in iotempower/etc/iotempower.conf.
EOF
exit 1
fi

# TODO: add network-manager detection and setup here

[ "$IOTEMPOWER_ACTIVE" = "yes" ] || { echo "IoTempower not active, aborting." 1>&2;exit 1; }

SHOW_ONLY=0
WLAN_OVERRIDE=""
WLAN2_OVERRIDE=""
GATEWAY_OVERRIDE=""
GATEWAY2_OVERRIDE=""
DOUBLE_NAT=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        show)
            SHOW_ONLY=1
            shift
            ;;
        --wlan)
            WLAN_OVERRIDE="$2"
            shift 2
            ;;
        --gateway)
            GATEWAY_OVERRIDE="$2"
            shift 2
            ;;
        --wlan2)
            WLAN2_OVERRIDE="$2"
            DOUBLE_NAT=1
            shift 2
            ;;
        --gateway2)
            GATEWAY2_OVERRIDE="$2"
            DOUBLE_NAT=1
            shift 2
            ;;
        --double-nat)
            DOUBLE_NAT=1
            shift
            ;;
        *)
            echo "Unknown option: $1" 1>&2
            exit 1
            ;;
    esac
done

if [[ "$SHOW_ONLY" -ne 1 ]]; then
    ufw_active=""
    sudo ufw status| grep "Status: active" &>/dev/null && ufw_active="true"
fi

while true; do

    # find input network device (device connected to internet)
    INPUT_DEVICE=$(ip route ls|grep default|head -n1|cut -d\  -f5)
    if [ ! "$INPUT_DEVICE" ]; then
      INPUT_DEVICE=lo
    fi

    # detect output wireless network device to start AP on
    available_wifi=$(echo $(ip link show|cut -d: -f2|grep " wl"|cut -b2-))
    OUTPUT_WIFI="$WLAN_OVERRIDE"
    if [[ ! "$OUTPUT_WIFI" ]]; then
        if [[ "$IOTEMPOWER_AP_DEVICES" ]]; then
            for possible in $(echo "$IOTEMPOWER_AP_DEVICES"); do
                if [[ "$available_wifi" =~ .*"$possible".* ]]; then
                    OUTPUT_WIFI="$possible"
                    break
                fi
            done
        else
            # Take first available
            OUTPUT_WIFI=$(ip link show|cut -d: -f2|grep " wl"|cut -b2-|tail -n1)
        fi
    fi

    OUTPUT_WIFI2="$WLAN2_OVERRIDE"
    if [[ "$DOUBLE_NAT" -eq 1 && ! "$OUTPUT_WIFI2" ]]; then
        for possible in $(echo "$IOTEMPOWER_AP_DEVICES"); do
            if [[ "$possible" != "$OUTPUT_WIFI" && "$available_wifi" =~ .*"$possible".* ]]; then
                OUTPUT_WIFI2="$possible"
                break
            fi
        done
    fi

    if [[ "$DOUBLE_NAT" -eq 1 && ! "$OUTPUT_WIFI2" ]]; then
        echo "double NAT needs a second interface (use --wlan2 or IOTEMPOWER_AP_DEVICES)." 1>&2
        exit 1
    fi
    if [[ "$DOUBLE_NAT" -eq 1 && "$OUTPUT_WIFI2" = "$OUTPUT_WIFI" ]]; then
        echo "double NAT needs a different second interface." 1>&2
        exit 1
    fi

    IOTEMPOWER_AP_NAME_FULL="$IOTEMPOWER_AP_NAME"
    if [ "$IOTEMPOWER_AP_ADDID" = "yes" ]; then
        # add prefix to essid based on network adapter for unique class setup
        OUTPUT_MAC=$(ip link show "$OUTPUT_WIFI"|tail -n1|\
                cut -d\  -f6|sed s/://g|cut -b7-)
        IOTEMPOWER_AP_NAME_FULL="${IOTEMPOWER_AP_NAME}-$OUTPUT_MAC"
    fi

    # add network extension for making essid more unique
    AP_NAME="$IOTEMPOWER_AP_NAME_FULL"
    AP_NAME2="${IOTEMPOWER_AP_NAME2:-${AP_NAME}-2}"

    PASSWORD="$IOTEMPOWER_AP_PASSWORD"

    CHANNEL="$IOTEMPOWER_AP_CHANNEL"
    if [ "$CHANNEL" = "random" ]; then
        # pick channel randomly
        CHANNEL=$(shuf -n 1 -e 2 3 4 5 7 8 9 10)
    fi
    CHANNEL2="${IOTEMPOWER_AP_CHANNEL2:-$CHANNEL}"

    IP="${GATEWAY_OVERRIDE:-$IOTEMPOWER_AP_IP}"
    IP2="${GATEWAY2_OVERRIDE:-$IOTEMPOWER_AP_IP2}"

    if [[ "$DOUBLE_NAT" -eq 1 && ! "$IP2" ]]; then
        echo "double NAT needs a second IP (use --gateway2 or IOTEMPOWER_AP_IP2)." 1>&2
        exit 1
    fi

    HIDDEN=""
    if [[ "$IOTEMPOWER_AP_HIDDEN" = "yes" ]]; then
        HIDDEN="--hidden"
    fi

    if [[ "$SHOW_ONLY" -eq 1 ]]; then
#        echo "ACCESSPOINT_NAME=$AP_NAME"
        echo "$AP_NAME"
        exit 0
    fi

    mkdir -p "$IOTEMPOWER_ROOT/tmp"
    HOSTFILE="$IOTEMPOWER_ROOT/tmp/ap-host"
    cat << EOF > "$HOSTFILE"
$IP gw.iotempire.net $IOTEMPOWER_AP_HOSTNAME.localnet $IOTEMPOWER_AP_HOSTNAME
EOF


    HOSTAPD_EXTRA=""
    if [[ "$IOTEMPOWER_AP_BRIDGE" ]]; then
        HOSTAPD_EXTRA="--hostapd-extra bridge=br0"
    fi

    echo "Stopping all existing services."
    sudo pkill -f lnxrouter
    sleep 2
    echo
    echo "Starting accesspoint with name $AP_NAME on channel $CHANNEL."
    echo "Will use $OUTPUT_WIFI with mac $OUTPUT_MAC to run an accesspoint."
    if [[ "$DOUBLE_NAT" -eq 1 ]]; then
        echo "double NAT enabled: starting second accesspoint $AP_NAME2 on $OUTPUT_WIFI2."
    fi
    echo "Internet-input device is $INPUT_DEVICE."
    echo
    sudo iptables -t nat -F POSTROUTING
    sudo iptables -t nat -F PREROUTING
    sudo iptables -F
    sudo iptables -t nat -F
    sudo iptables -t mangle -F
    sudo iptables -X
    if [[ "$IOTEMPOWER_AP_BRIDGE" ]]; then
        sudo ifconfig br0 down
        sudo brctl delbr br0
        sudo brctl addbr br0
        sudo brctl addif br0 "$IOTEMPOWER_AP_BRIDGE"
        sudo ifconfig br0 "$IP"
    fi
# sleep needs to be controlled from soemwhere outside this
#    sudo systemd-inhibit \
#        --who "accesspoint" \
#        --why "accesspoint will fail if sleep happens" \
    # udp forwarding seems not to work from 53->5353 seems not to work
    # on void linux
    # enable ip-forwarding
    sudo sysctl -w net.ipv4.ip_forward=1
    if [[ "$HOSTAPD_EXTRA" ]]; then
        echo "Warning: bridge mode is not supported with lnxrouter in this script and will be ignored."
    fi
    if [[ "$HIDDEN" ]]; then
        echo "Warning: hidden SSID mode is not supported with lnxrouter in this script and will be ignored."
    fi
    sudo lnxrouter --ap "$OUTPUT_WIFI" "$AP_NAME" \
        -p "$PASSWORD" \
        -g "$IP" \
        --freq-band 2.4 \
        --no-virt \
        -c "$CHANNEL" &
    ap_id1=$!
    if [[ "$DOUBLE_NAT" -eq 1 ]]; then
        sudo lnxrouter --ap "$OUTPUT_WIFI2" "$AP_NAME2" \
            -p "$PASSWORD" \
            -g "$IP2" \
            --freq-band 2.4 \
            --no-virt \
            -c "$CHANNEL2" &
        ap_id2=$!
    else
        ap_id2=""
    fi
    sleep 7 # let ap start up
    if [[ "$IOTEMPOWER_AP_BRIDGE" ]]; then
        # fix ip address
        sudo ifconfig "$OUTPUT_WIFI" 0.0.0.0
        sudo ifconfig br0 "$IP"
        sudo iptables -t nat -D POSTROUTING 1
        sudo iptables -t nat -A POSTROUTING -s "$IP"/24 \
                -o "$INPUT_DEVICE" -j MASQUERADE
    fi
    # make sure to restore firewall
    if [[ "$SHOW_ONLY" -ne 1 ]]; then
        if [[ "$ufw_active" ]]; then
            sudo ufw enable
        fi
        wait $ap_id1
        if [[ "$ap_id2" ]]; then
            wait $ap_id2
        fi
    fi
done
