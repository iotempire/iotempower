#!/usr/bin/env bash
if [[ $# -gt 0 || "$*" = "help" || "$*" = "-h" || "$*" = "--help" ]]; then
cat << EOF
Syntax: dongle_starter

Start dongle_daemon in a loop (restart when exit).
If no dongle present in beginning, exit.

EOF
exit 1
fi

[ "$IOTEMPOWER_ACTIVE" = "yes" ] || { echo "IoTempower not active, aborting." 1>&2;exit 1; }

# wait for wlap ...
sleep 15
if [ -z "${IOTEMPOWER_AP_NAME_FULL}" ]; then
    echo "WARNING: AP_NAME_FULL not defined, trying to pull from wlap0..."
    if command -v iw >/dev/null 2>&1; then
        export IOTEMPOWER_AP_NAME_FULL=$(iw dev wlap0 info 2>/dev/null | grep ssid | awk '{print $2}')
    fi
fi
echo "SSID: $IOTEMPOWER_AP_NAME_FULL"

while true; do
    sleep 1
    dongle daemon
    sleep 1
    dongle=""
    for i in {1..10}; do
        sleep 30
        echo -n "$i/10) Scanning for dongle... "
        if find_dongle &>/dev/null ; then
            dongle="yes"
            echo "found."
            break;
        else
            echo "no dongle connected."
        fi
    done
    if test "$dongle" != "yes"; then
        echo "No dongle connected after several minutes, exiting"
        exit 1
    fi
done

# TODO: make daemon only come up when a dongle is plugged in
